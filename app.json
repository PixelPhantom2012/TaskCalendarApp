{
  "expo": {
    "name": "new android",
    "slug": "new-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8AC7FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.newandroid.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to show your current location for events."
      }
    },
    "android": {
      "newArchEnabled": true,
      "package": "com.newandroid.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8AC7FF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A6FE3",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "new-android",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3004604-0076-43ef-b0b8-1f6f7ca44fc6"
      }
    }
  }
}
